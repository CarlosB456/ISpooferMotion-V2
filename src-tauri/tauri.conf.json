{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ISpooferMotion",
  "version": "2.3.0",
  "identifier": "ISpooferMotion-V2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Updater",
        "label": "splashscreen",
        "url": "splash.html",
        "width": 432,
        "height": 332,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$APPDATA/**",
          "$RESOURCE/**",
          "$PICTURE/**",
          "$VIDEO/**",
          "$DESKTOP/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$TEMP/**"
        ]
      },
      "csp": "default-src 'self' ipc: ipc://localhost http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src * 'self' asset: https: http: blob: data:; connect-src * 'self' http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https: ipc: ipc://localhost http://ipc.localhost tauri: asset:; media-src * 'self' asset: https: blob: data:; font-src 'self' data: https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": [
      "../dist-plugin/ISpooferMotion.rbxmx"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "assets/app_icon.ico",
        "uninstallerIcon": "assets/app_icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "ispoofermotion"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ISpooferMotion/ISpooferMotion-V2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4MzdCNUNFNjEwQTk5Q0QKUldUTm1RcGh6clUzT0hxaXlYR3BFK0tIck5jTDFrelgweFVaUDNHSG92TnpBWmJFTFd6MFQvdlYK"
    }
  }
}
