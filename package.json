{
  "name": "ispoofermotion",
  "version": "2.4.0",
  "description": "Animation spoofing utility for Roblox",
  "author": {
    "name": "IncredibroXP",
    "email": "incredibroxpdev@gmail.com"
  },
  "license": "GPL-3.0-or-later",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build:app": "vite build",
    "build:plugin": "bun scripts/build-plugin.mjs",
    "build": "run-s build:app build:plugin",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "tauri:dev": "bun scripts/clear-dev-state.mjs && tauri dev --config src-tauri/tauri.dev.conf.json",
    "format": "run-s format:prettier format:rust format:stylua",
    "format:check": "run-s format:prettier:check format:rust:check format:stylua:check",
    "format:prettier": "prettier --write .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:stylua": "bunx @johnnymorganz/stylua-bin .",
    "format:prettier:check": "prettier --check .",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "format:stylua:check": "bunx @johnnymorganz/stylua-bin --check .",
    "typecheck": "tsc --noEmit",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml --lib",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --lib --all-targets -- -D warnings",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "check": "run-s typecheck rust:check rust:lint rust:test lint test build"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.rs": [
      "cargo fmt --manifest-path src-tauri/Cargo.toml --"
    ],
    "*.luau": [
      "bunx @johnnymorganz/stylua-bin"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-global-shortcut": "2.3.2",
    "@tauri-apps/plugin-http": "2.5.9",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-os": "2.3.2",
    "@tauri-apps/plugin-process": "~2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "12.42.2",
    "fzstd": "0.1.1",
    "lenis": "1.3.25",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-colorful": "5.7.0",
    "react-dom": "19.2.7",
    "react-resizable-panels": "^4.12.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "3.6.0",
    "three": "0.185.1",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "2.27.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.1",
    "@srsholmes/tauri-playwright": "^0.4.1",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "^10.1.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all": "4.1.5",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
